# =============================================================================
# Imperium — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# =============================================================================

# --- Database (Neon / any PostgreSQL) ----------------------------------------
# Full connection string including SSL params if required by your provider.
# Example (Neon): postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Session -----------------------------------------------------------------
# Random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for the API server.
# Set to the public URL of your frontend (no trailing slash).
# Leave blank to allow all origins (dev only — not recommended for production).
ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# --- Email (Resend) ----------------------------------------------------------
# API key from https://resend.com — required for ticket confirmation emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "From" address used for outgoing emails (must be a verified Resend domain).
RESEND_FROM_EMAIL=support@yourdomain.com

# --- Server ------------------------------------------------------------------
# Port the API server listens on. Railway sets this automatically.
PORT=8080

# Node environment — set to "production" on Railway.
NODE_ENV=production
